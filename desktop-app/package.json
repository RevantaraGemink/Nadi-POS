{
  "name": "nadipos",
  "version": "1.0.0",
  "description": "Nadi POS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -w"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "@hono/node-server": "^2.0.2",
    "hono": "^4.12.18",
    "cors": "^2.8.6",
    "json2csv": "^6.0.0-alpha.2",
    "drizzle-orm": "^0.45.2",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nadipos.app",
    "productName": "Nadi POS",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"]
